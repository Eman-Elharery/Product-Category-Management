@model List<lab3.ViewModels.CategoryReadVM>



<style>

    *{
        text-align:center;
    }
    body{
        background-color: #E9E7E0;
    }
</style>
<h1 class="text-center mb-4">
    All Categories
</h1>

<table class="table table-hover table-bordered">
    <thead style="background-color:#679089; color:white;">
        <tr>
            <th>Name</th>
            <th>Products Count</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var category in Model)
        {
            <tr>
                <td>@category.Name</td>
                <td>@category.ProductsCount</td>
                <td>
                    <a class="btn btn-sm text-white px-4"
                       style="background-color:#679089;"
                       href="~/Category/Details/@category.Id">
                        View Details
                    </a>
                    <a class="btn btn-sm text-white px-4"
                       style="background-color:#A17630;"
                       href="~/Category/Edit/@category.Id">
                        Edit
                    </a>
                    <button class="btn btn-outline-danger"
                            data-bs-toggle="modal"
                            data-bs-target="#deleteModal"
                            onclick="setDeleteId(@category.Id)">
                        Delete
                    </button>
                    
                </td>
            </tr>
        }
    </tbody>
</table>
<a class="btn btn-sm text-white px-4"
   style="background-color:#56743C;"
   href="~/Category/Create">
    Add New Category
</a>

<a class="btn btn-sm text-white px-4"
   style=" background-color: #679089;
            color: white;"
   href="~/Product/Index">
    Go to Products
</a>

<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">

            <div class="modal-header">
                <h5 class="modal-title">Delete Product</h5>
            </div>

            <div class="modal-body">
                Are you sure you want to delete this Category ?
            </div>

            <div class="modal-footer">
                <form method="post" action="~/Category/DeleteConfirmed">
                    <input type="hidden" id="deleteId" name="id" />
                    <button type="submit" style="background-color:#9D4646;" class="btn btn-danger">Yes, Delete</button>
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                </form>
            </div>

        </div>
    </div>
</div>


@section Scripts{
    <script>
            function setDeleteId(id) {
            document.getElementById("deleteId").value = id;
           
        }
    </script>
}