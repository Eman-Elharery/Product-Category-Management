@model List<ASP.NETCoreD10.Models.ApplicationRole>
@{
    ViewData["Title"] = "Roles";
}

<style>
    body { background-color: #E9E7E0; }
    .purple-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(111, 66, 193, 0.2);
    }
    .purple-card .card-header {
        background-color: #679089;
        color: white;
        font-size: 20px;
        font-weight: bold;
    }
</style>

<div class="container mt-5">
    <div class="card purple-card">
        <div class="card-header d-flex justify-content-between align-items-center">
            <span>All Roles</span>
            <a asp-action="Create" class="btn btn-sm text-white px-4" style="background-color:#56743C;">
                + New Role
            </a>
        </div>
        <div class="card-body">
            @if (!Model.Any())
            {
                <div class="alert alert-info">No roles found.</div>
            }
            else
            {
                <table class="table table-hover align-middle">
                    <thead>
                        <tr style="background-color:#679089; color:white;">
                            <th>#</th>
                            <th>Role Name</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{ int i = 0; }
                        @foreach (var role in Model)
                        {
                            {
                                i++;
                            }
                            <tr>
                                <td>@i</td>
                                <td>@role.Name</td>
                                <td>
                                    <a asp-action="Edit" asp-route-id="@role.Id"
                                       class="btn btn-sm text-white px-3" style="background-color:#679089;">
                                        Edit
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@role.Id"
                                          method="post" class="d-inline"
                                          onsubmit="return confirm('Delete @role.Name ?')">
                                        <button type="submit"
                                                class="btn btn-sm text-white px-3" style="background-color:#9D4646;">
                                            Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
        </div>
    </div>
</div>

<a class="btn btn-sm text-white px-4 my-5"
   style=" background-color: #679089;
            color: white;"
   href="~/Welcome/Index">
    Back to Home
</a>

