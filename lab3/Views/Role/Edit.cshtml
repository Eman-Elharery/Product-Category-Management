@using ASP.NETCoreD10.Models
@model ApplicationRole
@{
    ViewData["Title"] = "Edit Role";
}

<style>
    body {
        background-color: #E9E7E0;
    }

    .purple-card {
        border: none;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(111, 66, 193, 0.2);
    }

        .purple-card .card-header {
            background-color: #679089;
            color: white;
            font-size: 20px;
            font-weight: bold;
        }

    .purple-label {
        font-weight: bold;
    }
</style>

<div class="container mt-5">
    <div class="card purple-card col-md-6 mx-auto">
        <div class="card-header text-center">
            Edit Role
        </div>
        <div class="card-body">
            <form asp-action="Edit" asp-route-id="@ViewBag.RoleId" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label purple-label"></label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <a asp-action="Index" asp-controller="Role"
                   class="btn btn-sm text-white px-4" style="background-color:#A17630;">Cancel</a>
                <input type="submit" value="Save"
                       class="btn btn-sm text-white px-4" style="background-color:#679089;" />
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
